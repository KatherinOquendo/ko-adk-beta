# OpenAI Codex CLI — ~/.codex/config.toml (or project .codex/config.toml)
# Wire with: codex mcp add workspace-mcp -- uvx workspace-mcp

[mcp_servers.google-workspace]
command = "uvx"
args = ["workspace-mcp", "--tool-tier", "core", "--tools", "gmail", "drive", "calendar", "docs", "sheets", "slides"]
startup_timeout_sec = 30
default_tools_approval_mode = "prompt"

[mcp_servers.google-workspace.env]
GOOGLE_OAUTH_CLIENT_ID = "${GOOGLE_OAUTH_CLIENT_ID}"
GOOGLE_OAUTH_CLIENT_SECRET = "${GOOGLE_OAUTH_CLIENT_SECRET}"
