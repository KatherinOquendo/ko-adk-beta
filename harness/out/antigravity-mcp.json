{
  "mcpServers": {
    "notebooklm": {
      "command": "notebooklm-mcp"
    },
    "stitch": {
      "serverUrl": "https://stitch.googleapis.com/mcp"
    },
    "google-workspace": {
      "command": "uvx",
      "args": [
        "workspace-mcp",
        "--tool-tier",
        "core",
        "--tools",
        "gmail",
        "drive",
        "calendar"
      ]
    }
  }
}
