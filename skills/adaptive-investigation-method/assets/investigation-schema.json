{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Adaptive Investigation Spec",
  "type": "object",
  "required": ["goal", "budget", "surface_map", "hypotheses", "deep_dives", "stop_reason", "deliverable"],
  "properties": {
    "goal": { "type": "string", "minLength": 1 },
    "budget": {
      "type": "object",
      "required": ["total"],
      "properties": {
        "total": { "type": "integer", "minimum": 1 },
        "used": { "type": "integer", "minimum": 0 },
        "unit": { "type": "string", "enum": ["reads", "tokens"] }
      }
    },
    "surface_root": { "type": "string" },
    "surface_map": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["node", "discovered_by"],
        "properties": {
          "node": { "type": "string" },
          "region": { "type": "string" },
          "discovered_by": { "type": "string", "description": "cheap tool used (Glob/Grep)" }
        }
      }
    },
    "hypotheses": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "rank", "target_nodes"],
        "properties": {
          "id": { "type": "string" },
          "rank": { "type": "integer", "minimum": 1 },
          "value_cost": { "type": "string" },
          "target_nodes": { "type": "array", "items": { "type": "string" } }
        }
      }
    },
    "deep_dives": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["node", "verdict", "provenance_tag"],
        "properties": {
          "node": { "type": "string" },
          "verdict": { "type": "string", "enum": ["confirm", "intact", "invalidated"] },
          "evidence": { "type": "string" },
          "provenance_tag": { "type": "string", "enum": ["[DOC]", "[CÓDIGO]", "[CONFIG]", "[INFERENCIA]", "[SUPUESTO]"] }
        }
      }
    },
    "replans": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["trigger", "invalidated_hypothesis"],
        "properties": {
          "trigger": { "type": "string", "const": "hypothesis_invalidated" },
          "invalidated_hypothesis": { "type": "string" },
          "evidence": { "type": "string" }
        }
      }
    },
    "stop_reason": { "type": "string", "enum": ["goal_resolved", "budget_exhausted", "goal_unresolved"] },
    "deliverable": { "type": "string", "minLength": 1 }
  }
}
