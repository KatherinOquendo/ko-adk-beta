{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "workspace-setup plan contract",
  "description": "Deterministic contract for a .jm-adk.local.json setup plan. Validated offline by scripts/validate_workspace_setup_plan.py.",
  "type": "object",
  "required": [
    "target_file",
    "mode",
    "runtime_preferences",
    "command_policy",
    "privacy_policy",
    "write_policy",
    "evidence",
    "validation_checks"
  ],
  "additionalProperties": false,
  "properties": {
    "target_file": { "type": "string", "const": ".jm-adk.local.json" },
    "mode": { "type": "string", "enum": ["dry-run", "apply"], "default": "dry-run" },
    "runtime_preferences": {
      "type": "object",
      "required": ["goal", "runtime", "autonomy", "workspace_area", "output_format"],
      "properties": {
        "goal": { "type": "string" },
        "runtime": { "type": "string" },
        "autonomy": { "type": "string" },
        "workspace_area": { "type": "string" },
        "output_format": { "type": "string" }
      }
    },
    "command_policy": {
      "type": "object",
      "required": ["allowed", "prohibited", "escalation_required"],
      "properties": {
        "allowed": { "type": "array", "items": { "type": "string" } },
        "prohibited": { "type": "array", "items": { "type": "string" } },
        "escalation_required": { "type": "array", "items": { "type": "string" } }
      }
    },
    "privacy_policy": {
      "type": "object",
      "required": ["local_only", "store_secrets", "redaction_categories", "secret_scan_completed"],
      "properties": {
        "local_only": { "type": "boolean", "const": true },
        "store_secrets": { "type": "boolean", "const": false },
        "redaction_categories": { "type": "array", "items": { "type": "string" }, "minItems": 1 },
        "secret_scan_completed": { "type": "boolean", "const": true }
      }
    },
    "write_policy": {
      "type": "object",
      "required": ["explicit_apply_required", "gitignore_covered", "force_required_for_overwrite"],
      "properties": {
        "explicit_apply_required": { "type": "boolean", "const": true },
        "gitignore_covered": { "type": "boolean", "const": true },
        "force_required_for_overwrite": { "type": "boolean", "const": true }
      }
    },
    "evidence": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["claim", "tag"],
        "properties": {
          "claim": { "type": "string" },
          "tag": { "type": "string", "enum": ["[CODE]", "[CONFIG]", "[DOC]", "[INFERENCE]", "[ASSUMPTION]"] }
        }
      }
    },
    "validation_checks": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": [
          "assets",
          "deterministic_scripts",
          "quality_criteria",
          "runtime_preferences",
          "command_policy",
          "privacy_policy",
          "write_policy",
          "evidence"
        ]
      },
      "allOf": [
        { "contains": { "const": "assets" } },
        { "contains": { "const": "deterministic_scripts" } },
        { "contains": { "const": "quality_criteria" } }
      ]
    }
  }
}
