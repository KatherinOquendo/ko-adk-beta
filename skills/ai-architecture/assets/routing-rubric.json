{
  "rubric": "ai-architecture-routing",
  "version": "1.0.0",
  "evidence_tags": ["[DOC]", "[CONFIG]", "[CÓDIGO]", "[INFERENCIA]", "[SUPUESTO]"],
  "intent_to_topic": [
    { "intent": "ground answers in our docs / cite sources", "topic": "rag-patterns" },
    { "intent": "pick embedding model / dimension / metric / index", "topic": "embedding-strategy" },
    { "intent": "make a prompt reliable / add guardrails / adversarial tests", "topic": "prompt-engineering" },
    { "intent": "force valid JSON / enum / typed output", "topic": "structured-output" },
    { "intent": "what the system does, for whom, autonomy, modes", "topic": "ai-conops" },
    { "intent": "assess an existing AI system for gaps", "topic": "audit" },
    { "intent": "dev/prod data flow, registry, CI/CD", "topic": "ai-pipeline-architecture" },
    { "intent": "internal code structure / 6-layer stack", "topic": "ai-software-architecture" },
    { "intent": "reusable structural solutions (feature store, champion-challenger)", "topic": "ai-design-patterns" },
    { "intent": "when to fine-tune / dataset readiness", "topic": "fine-tuning-prep" },
    { "intent": "build the designed system into code/config", "topic": "implementation" },
    { "intent": "conversational flow / fallback / escalation", "topic": "chatbot-design" },
    { "intent": "speech in/out, latency, barge-in", "topic": "voice-interface" }
  ],
  "tie_breakers": [
    { "between": ["rag-patterns", "embedding-strategy"], "rule": "model/dimension/metric question -> embedding-strategy; retrieval orchestration + grounding -> rag-patterns" },
    { "between": ["audit", "implementation"], "rule": "assess existing -> audit; build new -> implementation" },
    { "between": ["ai-conops", "ai-software-architecture"], "rule": "what/for-whom -> ai-conops (precedes); internal structure -> ai-software-architecture" }
  ],
  "gate": {
    "single_topic_in_enum": true,
    "single_playbook_read": true,
    "single_tag_family": true,
    "playbook_gate_satisfied": true,
    "depth_respected": true,
    "no_inline_improvisation": true
  },
  "governance": { "no_invented_prices": true, "no_client_pii": true, "single_brand": true }
}
